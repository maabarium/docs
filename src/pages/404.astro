---
import "../styles/custom.css";
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Page Not Found | Maabarium Docs</title>
    <meta
      name="description"
      content="The documentation page you requested could not be found."
    />
  </head>
  <body>
    <main class="error-shell">
      <section class="error-card" aria-labelledby="error-title">
        <img
          src="/images/maabarium-logo.png"
          alt="Maabarium logo"
          width="64"
          height="64"
          class="error-logo"
        />
        <div class="error-kicker">Documentation Route Missing</div>
        <h1 id="error-title">This page does not exist.</h1>
        <p>
          The docs URL may be outdated, or the content may have moved during a
          documentation reorganization.
        </p>
        <div class="error-actions">
          <a href="/" class="primary-link">Go to docs home</a>
          <a href="https://www.maabarium.com" class="secondary-link"
            >Visit the main site</a
          >
        </div>
      </section>
    </main>
  </body>
</html>

<style>
  .error-shell {
    min-height: 100vh;
    display: grid;
    place-items: center;
    padding: 2rem;
  }

  .error-card {
    width: min(100%, 44rem);
    border-radius: 2rem;
    border: 1px solid rgba(255, 255, 255, 0.08);
    background: rgba(255, 255, 255, 0.04);
    box-shadow:
      inset 0 1px 0 rgba(255, 255, 255, 0.04),
      0 24px 70px rgba(2, 6, 23, 0.42);
    padding: 2rem;
    text-align: center;
    backdrop-filter: blur(20px);
  }

  .error-logo {
    margin: 0 auto 1rem;
    border-radius: 1.25rem;
    box-shadow: 0 0 26px rgba(45, 212, 191, 0.18);
  }

  .error-kicker {
    color: #99f6e4;
    font-family: var(--font-data);
    font-size: 0.75rem;
    font-weight: 700;
    letter-spacing: 0.16em;
    text-transform: uppercase;
  }

  h1 {
    margin: 0.75rem 0 0;
    color: #f8fafc;
    font-size: clamp(2.25rem, 8vw, 3.75rem);
    line-height: 0.98;
  }

  p {
    margin: 1rem auto 0;
    max-width: 34rem;
    color: #cbd5e1;
    font-size: 1.05rem;
    line-height: 1.8;
  }

  .error-actions {
    display: flex;
    justify-content: center;
    gap: 1rem;
    flex-wrap: wrap;
    margin-top: 1.5rem;
  }

  .primary-link,
  .secondary-link {
    border-radius: 999px;
    font-weight: 800;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    padding: 0.9rem 1.2rem;
  }

  .primary-link {
    background: linear-gradient(90deg, #2dd4bf, #fbbf24);
    color: #04111d;
    border: 1px solid rgba(45, 212, 191, 0.2);
  }

  .secondary-link {
    background: rgba(255, 255, 255, 0.05);
    border: 1px solid rgba(255, 255, 255, 0.1);
    color: #e2e8f0;
  }
</style>
