---
import { DOCS_PRIVACY_PATH } from "../config";

const privacyPath = DOCS_PRIVACY_PATH;
---

<div id="maabarium-consent-banner" class="maabarium-consent-banner" hidden>
  <div
    class="maabarium-consent-banner__surface"
    role="dialog"
    aria-labelledby="maabarium-consent-title"
    aria-describedby="maabarium-consent-copy"
    aria-live="polite"
  >
    <div class="maabarium-consent-banner__copy">
      <div id="maabarium-consent-title" class="maabarium-consent-banner__eyebrow">
        Privacy-first by default
      </div>
      <p id="maabarium-consent-copy">
        This docs site only loads Google Analytics 4 after you opt in. Core docs functionality, search, and navigation stay available without analytics.
        <a href={privacyPath}>Read the privacy and analytics policy</a>.
      </p>
    </div>

    <div class="maabarium-consent-banner__actions">
      <button type="button" class="maabarium-consent-banner__button" data-analytics-consent="denied">
        Decline analytics
      </button>
      <button
        type="button"
        class="maabarium-consent-banner__button maabarium-consent-banner__button--accept"
        data-analytics-consent="granted"
      >
        Accept analytics
      </button>
    </div>
  </div>
</div>

<script is:inline>
  const grantedEventName = "maabarium:analytics-consent-granted";
  const deniedEventName = "maabarium:analytics-consent-denied";
  const analyticsConsentCookie = "maabarium_analytics_consent";
  const banner = document.getElementById("maabarium-consent-banner");

  const setCookie = (name, value, days = 365) => {
    const expires = new Date(
      Date.now() + days * 24 * 60 * 60 * 1000,
    ).toUTCString();
    document.cookie = `${name}=${value}; expires=${expires}; path=/; SameSite=Lax`;
  };

  const clearCookie = (name) => {
    document.cookie = `${name}=; expires=Thu, 01 Jan 1970 00:00:00 GMT; path=/; SameSite=Lax`;
  };

  const readCookie = (name) => {
    const prefix = `${name}=`;
    return document.cookie
      .split(";")
      .map((entry) => entry.trim())
      .find((entry) => entry.startsWith(prefix))
      ?.slice(prefix.length);
  };

  const updateConsentState = (granted) => {
    window.__maabariumAnalyticsConsent = granted;
    document.documentElement.dataset.analyticsConsent = granted
      ? "granted"
      : "denied";
    window.dispatchEvent(
      new CustomEvent(granted ? grantedEventName : deniedEventName),
    );
  };

  const showBanner = () => {
    banner?.removeAttribute("hidden");
  };

  const hideBanner = () => {
    banner?.setAttribute("hidden", "");
  };

  const persistChoice = (value) => {
    const granted = value === "granted";
    setCookie(analyticsConsentCookie, value);
    updateConsentState(granted);
    hideBanner();
  };

  const syncConsent = () => {
    const existingChoice = readCookie(analyticsConsentCookie);
    if (existingChoice === "granted" || existingChoice === "denied") {
      updateConsentState(existingChoice === "granted");
      hideBanner();
      return;
    }

    updateConsentState(false);
    showBanner();
  };

  banner?.addEventListener("click", (event) => {
    const target = event.target;
    if (!(target instanceof Element)) {
      return;
    }

    const button = target.closest("[data-analytics-consent]");
    if (!(button instanceof HTMLElement)) {
      return;
    }

    const value = button.getAttribute("data-analytics-consent");
    if (value === "granted" || value === "denied") {
      persistChoice(value);
    }
  });

  const openPreferences = () => {
    clearCookie(analyticsConsentCookie);
    updateConsentState(false);
    showBanner();
    banner
      ?.querySelector('[data-analytics-consent="granted"]')
      ?.focus();
  };

  window.addEventListener("maabarium:open-cookie-preferences", openPreferences);

  if (document.readyState === "loading") {
    document.addEventListener("DOMContentLoaded", syncConsent, { once: true });
  } else {
    syncConsent();
  }
</script>

<style>
  .maabarium-consent-banner {
    position: fixed;
    inset-inline: 1rem;
    bottom: 1rem;
    z-index: 100;
  }

  .maabarium-consent-banner__surface {
    display: grid;
    gap: 1rem;
    width: min(100%, 68rem);
    margin-inline: auto;
    border: 1px solid rgba(255, 255, 255, 0.12);
    border-radius: 1.5rem;
    background:
      linear-gradient(90deg, rgba(45, 212, 191, 0.08), rgba(251, 191, 36, 0.06)),
      rgba(2, 6, 23, 0.94);
    box-shadow: 0 24px 60px rgba(2, 6, 23, 0.42);
    backdrop-filter: blur(24px);
    padding: 1rem 1.1rem;
  }

  .maabarium-consent-banner__eyebrow {
    color: #99f6e4;
    font-family: var(--font-data);
    font-size: 0.68rem;
    font-weight: 800;
    letter-spacing: 0.18em;
    text-transform: uppercase;
  }

  .maabarium-consent-banner__copy p {
    margin: 0.45rem 0 0;
    color: #dbe4ef;
    line-height: 1.65;
  }

  .maabarium-consent-banner__copy a {
    color: #ccfbf1;
  }

  .maabarium-consent-banner__actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
  }

  .maabarium-consent-banner__button {
    border: 1px solid rgba(255, 255, 255, 0.14);
    border-radius: 999px;
    background: rgba(255, 255, 255, 0.05);
    color: #f8fafc;
    font-family: var(--font-data);
    font-size: 0.8rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    padding: 0.85rem 1rem;
    text-transform: uppercase;
  }

  .maabarium-consent-banner__button--accept {
    background: linear-gradient(90deg, #2dd4bf, #fbbf24);
    border-color: rgba(45, 212, 191, 0.25);
    color: #04111d;
  }

  @media (min-width: 52rem) {
    .maabarium-consent-banner__surface {
      grid-template-columns: minmax(0, 1fr) auto;
      align-items: center;
      padding: 1.05rem 1.2rem;
    }

    .maabarium-consent-banner__actions {
      justify-content: flex-end;
    }
  }
</style>