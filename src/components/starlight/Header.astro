---
const navItems = [
  { label: 'Install', href: '/getting-started/install/' },
  { label: 'First Run', href: '/getting-started/first-run/' },
  { label: 'Blueprints', href: '/guides/workflows-and-blueprints/' },
  { label: 'Reference', href: '/reference/cli-and-runtime/' },
  { label: 'Community', href: '/community/contributing/' },
];
---

<header
  id="site-header"
  class="site-header sticky top-0 z-50"
>
  <div class="site-container flex items-center justify-between">
    <a href="/" class="flex items-center gap-3" aria-label="Maabarium Docs home">
      <img
        src="/images/maabarium-logo.png"
        alt="Maabarium logo"
        class="h-11 w-11 rounded-2xl shadow-[0_0_26px_rgba(45,212,191,0.18)]"
        width="44"
        height="44"
      />
      <div>
        <div class="text-lg font-black tracking-tight text-white md:text-xl">MAABARIUM</div>
        <div class="text-[10px] font-black uppercase tracking-[0.28em] text-slate-500">
          Open Source Research Lab
        </div>
      </div>
    </a>

    <nav class="site-header__nav-shell hidden items-center gap-2 rounded-full border border-white/10 bg-white/5 p-1.5 md:flex" aria-label="Primary">
      {navItems.map((item) => (
        <a
          href={item.href}
          class="rounded-full px-4 py-2 text-xs font-black uppercase tracking-[0.16em] text-slate-400 transition hover:bg-white/5 hover:text-white"
        >
          {item.label}
        </a>
      ))}
    </nav>

    <div class="hidden items-center gap-3 md:flex">
      <a
        href="https://github.com/maabarium/core/releases/latest"
        class="btn-secondary"
        target="_blank"
        rel="noreferrer"
      >
        Latest release
      </a>
      <a href="https://github.com/maabarium/core" class="btn-primary" target="_blank" rel="noreferrer">
        View on GitHub
      </a>
    </div>

    <details class="relative md:hidden">
      <summary class="list-none rounded-full border border-white/10 bg-white/5 px-4 py-3 text-sm font-black text-white marker:hidden">
        Menu
      </summary>
      <div class="absolute right-0 mt-3 min-w-[15rem] rounded-3xl border border-white/10 bg-slate-950/95 p-3 shadow-2xl backdrop-blur-2xl">
        <nav class="flex flex-col gap-1" aria-label="Mobile">
          {navItems.map((item) => (
            <a href={item.href} class="rounded-2xl px-4 py-3 text-sm font-bold text-slate-300 transition hover:bg-white/5 hover:text-white">{item.label}</a>
          ))}
          <a
            href="https://github.com/maabarium/core/releases/latest"
            class="rounded-2xl px-4 py-3 text-sm font-bold text-slate-300 transition hover:bg-white/5 hover:text-white"
            target="_blank"
            rel="noreferrer"
          >
            Latest release
          </a>
          <a
            href="https://github.com/maabarium/core"
            class="rounded-2xl bg-teal-400 px-4 py-3 text-sm font-black text-slate-950"
            target="_blank"
            rel="noreferrer"
          >
            View on GitHub
          </a>
        </nav>
      </div>
    </details>
  </div>
</header>

<script is:inline>
  const header = document.getElementById('site-header');
  const headerShell = header?.closest('.header');

  if (header) {
    const syncHeaderState = () => {
      const scrolled = window.scrollY > 18 ? 'true' : 'false';

      header.dataset.scrolled = scrolled;

      if (headerShell instanceof HTMLElement) {
        headerShell.dataset.scrolled = scrolled;
      }
    };

    syncHeaderState();
    window.addEventListener('scroll', syncHeaderState, { passive: true });
  }
</script>